# vLLM Configuration
# Copy to .env and configure

# ============================================
# Model Selection (HuggingFace equivalents of Ollama models)
# ============================================

# DeepSeek-R1 32B (like deepseek-r1:32b) - DEFAULT
MODEL=deepseek-ai/DeepSeek-R1-Distill-Qwen-32B

# DeepSeek-R1 70B (like deepseek-r1:70b)
# MODEL=deepseek-ai/DeepSeek-R1-Distill-Llama-70B

# Llama 3.3 70B (like llama3.3:latest)
# MODEL=meta-llama/Llama-3.3-70B-Instruct

# Qwen 2.5 Coder 32B (like qwen3-coder:30b)
# MODEL=Qwen/Qwen2.5-Coder-32B-Instruct

# Mixtral 8x7B (like mixtral:latest)
# MODEL=mistralai/Mixtral-8x7B-Instruct-v0.1

# ============================================
# GPU Configuration
# ============================================

# Tensor parallel size (number of GPUs)
TP_SIZE=3

# GPU selection
CUDA_VISIBLE_DEVICES=0,1,2

# Max context length
MAX_MODEL_LEN=4096

# ============================================
# Authentication
# ============================================

# HuggingFace token (required for gated models like Llama)
HUGGING_FACE_HUB_TOKEN=hf_xxxxxxxxxxxxx
